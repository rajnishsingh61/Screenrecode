rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Validation
    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             (data.get('displayName', '') is string && data.get('displayName', '').size() <= 100) &&
             (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 500) &&
             data.isPremium is bool &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // No blanket reads of user list
      
      allow create: if isOwner(userId) && 
                      isValidId(userId) && 
                      isValidUser(incoming()) &&
                      incoming().createdAt == request.time &&
                      incoming().updatedAt == request.time &&
                      incoming().isPremium == false; // Start as non-premium
                      
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) &&
                      incoming().uid == existing().uid &&
                      incoming().email == existing().email &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time &&
                      (incoming().isPremium == existing().isPremium || incoming().diff(existing()).affectedKeys().hasOnly(['isPremium', 'updatedAt', 'displayName', 'photoURL']));
                      
      allow delete: if false;
    }

    match /app_config/settings {
      allow read: if isSignedIn();
      allow write: if isOwner("singhrajnish52741@gmail.com"); // Hardcoded admin for now as requested by user email
    }

    match /premium_requests/{requestId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isOwner("singhrajnish52741@gmail.com"));
      allow list: if isOwner("singhrajnish52741@gmail.com");
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isOwner("singhrajnish52741@gmail.com");
    }
  }
}
